{
  "version": 2,
  "name": "stragentech-apps",
  "rewrites": [
    {
      "source": "/api/analyze",
      "destination": "/api/analyze.js"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "apps.stragentech.com"
        }
      ],
      "destination": "/apps.html",
      "permanent": false
    }
  ]
}